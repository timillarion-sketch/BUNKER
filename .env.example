# Database
DATABASE_URL=postgresql://user:password@host:5432/db
POSTGRES_USER=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bunker_db

# JWT (generate with: openssl rand -hex 32)
JWT_SECRET=replace-with-random-64-char-hex-string!!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session (generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-another-random-64-char-hex-string!!!

# n8n webhook
N8N_WEBHOOK=https://your-n8n-instance.com/webhook/bunker

# Server
PORT=8080
NODE_ENV=development
BASE_PATH=/
LOG_LEVEL=info

# API public URL (used to build OAuth callback URLs)
API_URL=http://localhost:4000

# Frontend URL (for OAuth callback redirects)
FRONTEND_URL=http://localhost:80

# VK OAuth
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# Yandex OAuth
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
